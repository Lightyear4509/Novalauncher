<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:NovaLauncher.Views"
    xmlns:viewModels="using:NovaLauncher.ViewModels"
    xmlns:models="using:NovaLauncher.Models"
    x:Class="NovaLauncher.Views.MainWindow"
    x:DataType="viewModels:MainWindowViewModel"
    Title="NovaLauncher"
    Width="1180"
    Height="720"
    MinWidth="900"
    MinHeight="600"
    Background="#0E1117">

	<Grid ColumnDefinitions="210,*">

		<!-- Left sidebar -->
		<Border
            Grid.Column="0"
            Background="#151922"
            BorderBrush="#292F3D"
            BorderThickness="0,0,1,0">

			<Grid
                Margin="18"
                RowDefinitions="Auto,Auto,*,Auto">

				<!-- App title -->
				<StackPanel
                    Grid.Row="0"
                    Margin="4,8,4,28"
                    Spacing="4">

					<TextBlock
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="NovaLauncher" />

					<TextBlock
                        FontSize="12"
                        Foreground="#7F8A9A"
                        Text="Game Library" />

				</StackPanel>

				<!-- Navigation -->
				<StackPanel
                    Grid.Row="1"
                    Spacing="8">

					<Button
                        Padding="14,11"
                        HorizontalContentAlignment="Left"
                        Command="{Binding ShowLibraryCommand}"
                        Content="🎮  Library" />

					<Button
                        Padding="14,11"
                        HorizontalContentAlignment="Left"
                        Command="{Binding ShowFavoritesCommand}"
                        Content="★  Favorites" />

					<Button
                        Padding="14,11"
                        HorizontalContentAlignment="Left"
                        Command="{Binding ShowRecentlyAddedCommand}"
                        Content="◷  Recently Added" />

				</StackPanel>

				<!-- Bottom navigation -->
				<StackPanel
                    Grid.Row="3"
                    Spacing="8">

					<Button
                        Padding="14,11"
                        HorizontalContentAlignment="Left"
                        Content="⚙  Settings" />

					<TextBlock
                        Margin="8,8,0,0"
                        FontSize="11"
                        Foreground="#667085"
                        Text="NovaLauncher v0.1" />

				</StackPanel>

			</Grid>
		</Border>

		<!-- Main application area -->
		<Grid
            Grid.Column="1"
            RowDefinitions="Auto,*">

			<!-- Top toolbar -->
			<Border
                Grid.Row="0"
                Padding="24,14"
                Background="#171B24"
                BorderBrush="#292F3D"
                BorderThickness="0,0,0,1">

				<Grid RowDefinitions="Auto,Auto">

					<!-- Library heading -->
					<StackPanel
                        Grid.Row="0"
                        Spacing="2">

						<TextBlock
                            FontSize="21"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="Library" />

						<TextBlock
                            FontSize="12"
                            Foreground="#98A2B3"
                            Text="{Binding LibraryCount}" />

					</StackPanel>

					<!-- Toolbar controls -->
					<WrapPanel
                        Grid.Row="1"
                        Margin="0,14,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left">

						<TextBox
                            Width="220"
                            Margin="0,0,12,8"
                            VerticalAlignment="Center"
                            PlaceholderText="Search games..."
                            Text="{Binding SearchText}" />

						<ComboBox
                            Width="160"
                            Margin="0,0,12,8"
                            VerticalAlignment="Center"
                            ItemsSource="{Binding SortOptions}"
                            SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}" />

						<Button
                            Margin="0,0,12,8"
                            Padding="18,10"
                            VerticalAlignment="Center"
                            Command="{Binding AddGameCommand}"
                            Content="+ Add Game" />

						<Button
                            Margin="0,0,0,8"
                            Padding="18,10"
                            VerticalAlignment="Center"
                            Command="{Binding ImportSteamGamesCommand}"
                            Content="Import Steam" />

					</WrapPanel>

				</Grid>
			</Border>

			<!-- Library content -->
			<Grid
                Grid.Row="1"
                Margin="24"
                ColumnDefinitions="2*,*">

				<!-- Game list -->
				<Border
                    Grid.Column="0"
                    Padding="16"
                    Background="#171B24"
                    BorderBrush="#303747"
                    BorderThickness="1"
                    CornerRadius="12">

					<Grid RowDefinitions="Auto,*,Auto">

						<TextBlock
                            Grid.Row="0"
                            Margin="4,0,0,14"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="All Games" />

						<ListBox
                            x:Name="GameList"
                            Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemsSource="{Binding FilteredGames}"
                            SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                            SelectionChanged="GameList_SelectionChanged"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                            ScrollViewer.VerticalScrollBarVisibility="Auto">

							<ListBox.Styles>

								<Style Selector="ListBoxItem">
									<Setter Property="Padding" Value="0" />
									<Setter Property="Margin" Value="0" />
									<Setter Property="Background" Value="Transparent" />
									<Setter
                                        Property="HorizontalContentAlignment"
                                        Value="Stretch" />
									<Setter
                                        Property="VerticalContentAlignment"
                                        Value="Stretch" />
								</Style>

								<Style Selector="ListBoxItem /template/ ContentPresenter">
									<Setter Property="Padding" Value="0" />
									<Setter Property="Background" Value="Transparent" />
									<Setter Property="BorderBrush" Value="Transparent" />
									<Setter Property="BorderThickness" Value="2" />
									<Setter Property="CornerRadius" Value="11" />
								</Style>

								<Style
                                    Selector="ListBoxItem:pointerover /template/ ContentPresenter">
									<Setter Property="Background" Value="Transparent" />
									<Setter Property="BorderBrush" Value="#596579" />
								</Style>

								<Style
                                    Selector="ListBoxItem:selected /template/ ContentPresenter">
									<Setter Property="Background" Value="Transparent" />
									<Setter Property="BorderBrush" Value="#5CAEFF" />
								</Style>

							</ListBox.Styles>

							<ListBox.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Left"
                                        ItemSpacing="16"
                                        LineSpacing="16" />
								</ItemsPanelTemplate>
							</ListBox.ItemsPanel>

							<ListBox.ItemTemplate>
								<DataTemplate x:DataType="models:Game">
									<views:GameCard />
								</DataTemplate>
							</ListBox.ItemTemplate>

						</ListBox>

						<TextBlock
                            Grid.Row="2"
                            Margin="4,14,0,0"
                            Foreground="#98A2B3"
                            Text="{Binding LibraryCount}" />

					</Grid>
				</Border>

				<!-- Selected game details -->
				<Border
                    Grid.Column="1"
                    Margin="24,0,0,0"
                    Padding="30"
                    Background="#171B24"
                    BorderBrush="#303747"
                    BorderThickness="1"
                    CornerRadius="12">

					<Grid RowDefinitions="260,Auto,Auto,Auto,Auto,Auto">

						<!-- Cover preview -->
						<Border
                            Grid.Row="0"
                            Background="#252C39"
                            CornerRadius="10"
                            ClipToBounds="True">

							<Grid>

								<StackPanel
                                    x:Name="CoverPlaceholder"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="10">

									<TextBlock
                                        HorizontalAlignment="Center"
                                        FontSize="70"
                                        Text="🎮" />

									<TextBlock
                                        Foreground="#98A2B3"
                                        Text="No cover selected" />

								</StackPanel>

								<Image
                                    x:Name="CoverImage"
                                    IsVisible="False"
                                    Stretch="UniformToFill" />

							</Grid>
						</Border>

						<!-- Editable game name -->
						<StackPanel
                            Grid.Row="1"
                            Margin="0,22,0,0"
                            Spacing="7">

							<TextBlock
                                FontWeight="SemiBold"
                                Foreground="#98A2B3"
                                Text="Display name" />

							<TextBox
                                x:Name="GameNameTextBox"
                                FontSize="20"
                                PlaceholderText="Game name"
                                IsEnabled="False"
                                Text="{Binding GameName, Mode=TwoWay}" />

						</StackPanel>

						<!-- Executable path -->
						<TextBlock
                            Grid.Row="2"
                            Margin="0,14,0,0"
                            Foreground="#AAB3C2"
                            Text="{Binding SelectedGamePath}"
                            TextWrapping="Wrap" />

						<!-- Editing buttons -->
						<WrapPanel
                            Grid.Row="3"
                            Margin="0,16,0,0"
                            Orientation="Horizontal">

							<Button
                                x:Name="SaveNameButton"
                                Margin="0,0,10,10"
                                Padding="16,9"
                                Command="{Binding SaveNameCommand}"
                                Content="Save Name"
                                IsEnabled="False" />

							<Button
                                x:Name="ChooseCoverButton"
                                Margin="0,0,10,10"
                                Padding="16,9"
                                Command="{Binding ChooseCoverCommand}"
                                Content="Choose Cover"
                                IsEnabled="False" />

							<Button
                                Margin="0,0,10,10"
                                Padding="16,9"
                                Command="{Binding ToggleFavoriteCommand}"
                                Content="{Binding FavoriteButtonText}" />

							<Button
                                x:Name="RemoveCoverButton"
                                Margin="0,0,10,10"
                                Padding="16,9"
                                Command="{Binding RemoveCoverCommand}"
                                Content="Remove Cover"
                                IsEnabled="False" />

						</WrapPanel>

						<!-- Status -->
						<Border
                            Grid.Row="4"
                            Margin="0,18,0,0"
                            Padding="12"
                            Background="#202632"
                            BorderBrush="#303747"
                            BorderThickness="1"
                            CornerRadius="8">

							<TextBlock
                                Foreground="#C8D1E0"
                                Text="{Binding StatusText}"
                                TextWrapping="Wrap" />

						</Border>

						<!-- Game actions -->
						<Grid
                            Grid.Row="5"
                            Margin="0,24,0,0"
                            ColumnDefinitions="*,Auto">

							<Button
                                Grid.Column="0"
                                Padding="20,13"
                                Command="{Binding LaunchGameCommand}"
                                Content="▶ Play" />

							<Button
                                Grid.Column="1"
                                Margin="12,0,0,0"
                                Padding="20,13"
                                Command="{Binding RemoveGameCommand}"
                                Content="Remove" />

						</Grid>

					</Grid>
				</Border>

			</Grid>
		</Grid>
	</Grid>
</Window>