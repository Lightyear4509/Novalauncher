<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:NovaLauncher.Views"
    xmlns:viewModels="using:NovaLauncher.ViewModels"
    xmlns:models="using:NovaLauncher.Models"
    x:Class="NovaLauncher.Views.MainWindow"
    x:DataType="viewModels:MainWindowViewModel"
    Title="NovaLauncher"
    Width="1440"
    Height="880"
    MinWidth="1050"
    MinHeight="700"
    Background="#0E141B">

	<Window.Styles>

		<Style Selector="Button">
			<Setter Property="CornerRadius" Value="5" />
			<Setter Property="Background" Value="#263646" />
			<Setter Property="BorderBrush" Value="#364A5E" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Foreground" Value="#DDE8F1" />
			<Setter Property="FontWeight" Value="SemiBold" />
		</Style>

		<Style Selector="Button:pointerover">
			<Setter Property="Background" Value="#33495E" />
			<Setter Property="BorderBrush" Value="#4B657D" />
		</Style>

		<Style Selector="Button.primaryButton">
			<Setter Property="Padding" Value="18,11" />
			<Setter Property="Background" Value="#1A9FFF" />
			<Setter Property="BorderBrush" Value="#1A9FFF" />
			<Setter Property="Foreground" Value="White" />
			<Setter Property="FontWeight" Value="Bold" />
		</Style>

		<Style Selector="Button.primaryButton:pointerover">
			<Setter Property="Background" Value="#39AEFF" />
			<Setter Property="BorderBrush" Value="#39AEFF" />
		</Style>

		<Style Selector="Button.navButton">
			<Setter Property="Padding" Value="14,12" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderBrush" Value="Transparent" />
			<Setter Property="Foreground" Value="#A5B2BF" />
		</Style>

		<Style Selector="Button.navButton:pointerover">
			<Setter Property="Background" Value="#1D2A36" />
			<Setter Property="Foreground" Value="White" />
		</Style>

		<Style Selector="TextBox.searchBox">
			<Setter Property="Padding" Value="14,10" />
			<Setter Property="CornerRadius" Value="5" />
			<Setter Property="Background" Value="#17212B" />
			<Setter Property="BorderBrush" Value="#304253" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Foreground" Value="White" />
		</Style>

		<Style Selector="TextBox.searchBox:focus">
			<Setter Property="BorderBrush" Value="#66C0F4" />
		</Style>

		<Style Selector="ComboBox.sortBox">
			<Setter Property="Padding" Value="12,9" />
			<Setter Property="CornerRadius" Value="5" />
			<Setter Property="Background" Value="#17212B" />
			<Setter Property="BorderBrush" Value="#304253" />
			<Setter Property="BorderThickness" Value="1" />
			<Setter Property="Foreground" Value="White" />
		</Style>

	</Window.Styles>

	<Grid ColumnDefinitions="230,*">

		<!-- Sidebar -->
		<Border
            Grid.Column="0"
            Background="#171D25"
            BorderBrush="#2A3541"
            BorderThickness="0,0,1,0">

			<Grid
                Margin="15"
                RowDefinitions="Auto,Auto,*,Auto">

				<Grid
                    Grid.Row="0"
                    Margin="5,12,5,32"
                    ColumnDefinitions="Auto,*">

					<Border
                        Width="44"
                        Height="44"
                        Background="#1A9FFF"
                        CornerRadius="7">

						<TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="22"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="N" />

					</Border>

					<StackPanel
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        VerticalAlignment="Center">

						<TextBlock
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="NovaLauncher" />

						<TextBlock
                            FontSize="10"
                            Foreground="#63788B"
                            Text="GAME LIBRARY" />

					</StackPanel>

				</Grid>

				<StackPanel
                    Grid.Row="1"
                    Spacing="5">

					<TextBlock
                        Margin="12,0,0,8"
                        FontSize="10"
                        FontWeight="Bold"
                        Foreground="#607386"
                        Text="LIBRARY" />

					<Button
                        Classes="navButton"
                        Command="{Binding ShowLibraryCommand}"
                        Content="▦   All Games" />

					<Button
                        Classes="navButton"
                        Command="{Binding ShowFavoritesCommand}"
                        Content="★   Favorites" />

					<Button
                        Classes="navButton"
                        Command="{Binding ShowRecentlyAddedCommand}"
                        Content="◷   Recently Added" />

				</StackPanel>

				<StackPanel
                    Grid.Row="3"
                    Spacing="9">

					<Border
                        Padding="14"
                        Background="#111820"
                        BorderBrush="#2A3948"
                        BorderThickness="1"
                        CornerRadius="6">

						<StackPanel Spacing="4">

							<TextBlock
                                FontSize="10"
                                FontWeight="Bold"
                                Foreground="#607386"
                                Text="YOUR COLLECTION" />

							<TextBlock
                                FontSize="18"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{Binding LibraryCount}" />

						</StackPanel>

					</Border>

					<TextBlock
                        Margin="12,7,0,2"
                        FontSize="10"
                        Foreground="#536575"
                        Text="NovaLauncher v0.2" />

				</StackPanel>

			</Grid>

		</Border>

		<!-- Main application area -->
		<Grid Grid.Column="1">

			<!-- Library page -->
			<Grid
                IsVisible="{Binding IsLibraryPageVisible}"
                RowDefinitions="Auto,*">

				<Border
                    Grid.Row="0"
                    Padding="25,17"
                    Background="#19232D"
                    BorderBrush="#2B3946"
                    BorderThickness="0,0,0,1">

					<Grid ColumnDefinitions="*,Auto">

						<StackPanel Spacing="2">

							<TextBlock
                                FontSize="23"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="{Binding SelectedLibraryView}" />

							<TextBlock
                                FontSize="11"
                                Foreground="#71869A"
                                Text="Browse and launch your PC game collection" />

						</StackPanel>

						<StackPanel
                            Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Spacing="10">

							<TextBox
                                Width="245"
                                Classes="searchBox"
                                PlaceholderText="Search games..."
                                Text="{Binding SearchText, Mode=TwoWay}" />

							<ComboBox
                                Width="170"
                                Classes="sortBox"
                                ItemsSource="{Binding SortOptions}"
                                SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}" />

							<Button
                                Padding="17,11"
                                Command="{Binding ImportSteamGamesCommand}"
                                Content="Import Steam" />

							<Button
                                Classes="primaryButton"
                                Command="{Binding AddGameCommand}"
                                Content="+ Add Game" />

						</StackPanel>

					</Grid>

				</Border>

				<Grid
                    Grid.Row="1"
                    Margin="24"
                    RowDefinitions="Auto,*,Auto">

					<Grid
                        Grid.Row="0"
                        Margin="0,0,0,18"
                        ColumnDefinitions="*,Auto">

						<StackPanel Spacing="4">

							<TextBlock
                                FontSize="22"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="Your Games" />

							<TextBlock
                                FontSize="12"
                                Foreground="#71869A"
                                Text="Click a game to open its game page" />

						</StackPanel>

						<Border
                            Grid.Column="1"
                            Padding="11,6"
                            VerticalAlignment="Center"
                            Background="#20384D"
                            CornerRadius="4">

							<TextBlock
                                FontWeight="Bold"
                                Foreground="#66C0F4"
                                Text="{Binding LibraryCount}" />

						</Border>

					</Grid>

					<ListBox
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        ItemsSource="{Binding FilteredGames}"
                        SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Auto">

						<ListBox.Styles>

							<Style Selector="ListBoxItem">
								<Setter Property="Padding" Value="0" />
								<Setter Property="Margin" Value="0" />
								<Setter Property="Background" Value="Transparent" />
								<Setter Property="HorizontalContentAlignment" Value="Stretch" />
								<Setter Property="VerticalContentAlignment" Value="Stretch" />
							</Style>

							<Style Selector="ListBoxItem /template/ ContentPresenter">
								<Setter Property="Padding" Value="0" />
								<Setter Property="Background" Value="Transparent" />
								<Setter Property="BorderBrush" Value="Transparent" />
							</Style>

						</ListBox.Styles>

						<ListBox.ItemsPanel>
							<ItemsPanelTemplate>

								<WrapPanel
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Left"
                                    ItemSpacing="17"
                                    LineSpacing="17" />

							</ItemsPanelTemplate>
						</ListBox.ItemsPanel>

						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="models:Game">
								<views:GameCard />
							</DataTemplate>
						</ListBox.ItemTemplate>

					</ListBox>

					<Border
                        Grid.Row="2"
                        Margin="0,16,0,0"
                        Padding="12,9"
                        Background="#111820"
                        CornerRadius="5">

						<TextBlock
                            FontSize="11"
                            Foreground="#71869A"
                            Text="{Binding StatusText}"
                            TextTrimming="CharacterEllipsis" />

					</Border>

				</Grid>

			</Grid>

			<!-- Full game page -->
			<views:GameDetails
                IsVisible="{Binding IsGamePageVisible}" />

		</Grid>

	</Grid>

</Window>