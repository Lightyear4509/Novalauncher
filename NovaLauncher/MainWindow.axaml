<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:models="using:NovaLauncher.Models"
    x:Class="NovaLauncher.Views.MainWindow"
    Title="NovaLauncher"
    Width="1050"
    Height="680"
    MinWidth="800"
    MinHeight="520"
    Background="#10131A">

	<Grid RowDefinitions="70,*">

		<!-- Header -->
		<Border
            Grid.Row="0"
            Background="#171B24"
            BorderBrush="#292F3D"
            BorderThickness="0,0,0,1">

			<Grid
                Margin="24,0"
                ColumnDefinitions="Auto,*,Auto">

				<TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="NovaLauncher" />

				<TextBlock
                    Grid.Column="1"
                    Margin="35,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#98A2B3"
                    Text="Your personal game library" />

				<Button
                    Grid.Column="2"
                    Padding="18,10"
                    VerticalAlignment="Center"
                    Click="AddGameButton_Click"
                    Content="+ Add Game" />

			</Grid>
		</Border>

		<!-- Main content -->
		<Grid
            Grid.Row="1"
            Margin="24"
            ColumnDefinitions="360,*">

			<!-- Library -->
			<Border
                Grid.Column="0"
                Padding="16"
                Background="#171B24"
                BorderBrush="#303747"
                BorderThickness="1"
                CornerRadius="12">

				<Grid RowDefinitions="Auto,*,Auto">

					<TextBlock
                        Grid.Row="0"
                        Margin="4,0,0,14"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Game Library" />

					<ListBox
                        x:Name="GameList"
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
                        SelectionChanged="GameList_SelectionChanged">

						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="models:Game">

								<Border
                                    Margin="0,4"
                                    Padding="12"
                                    Background="#202632"
                                    CornerRadius="8">

									<StackPanel Spacing="5">

										<TextBlock
                                            FontSize="17"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding Name}" />

										<TextBlock
                                            MaxWidth="300"
                                            Foreground="#98A2B3"
                                            Text="{Binding ExecutablePath}"
                                            TextTrimming="CharacterEllipsis" />

									</StackPanel>
								</Border>

							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>

					<TextBlock
                        x:Name="LibraryCountText"
                        Grid.Row="2"
                        Margin="4,14,0,0"
                        Foreground="#98A2B3"
                        Text="0 games" />

				</Grid>
			</Border>

			<!-- Selected game details -->
			<Border
                Grid.Column="1"
                Margin="24,0,0,0"
                Padding="30"
                Background="#171B24"
                BorderBrush="#303747"
                BorderThickness="1"
                CornerRadius="12">

				<Grid RowDefinitions="260,Auto,Auto,*,Auto">

					<Border
                        Grid.Row="0"
                        Background="#252C39"
                        CornerRadius="10">

						<StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">

							<TextBlock
                                HorizontalAlignment="Center"
                                FontSize="70"
                                Text="🎮" />

							<TextBlock
                                Foreground="#98A2B3"
                                Text="Cover art coming later" />

						</StackPanel>
					</Border>

					<TextBlock
                        x:Name="SelectedGameTitleText"
                        Grid.Row="1"
                        Margin="0,24,0,0"
                        FontSize="30"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Select a game" />

					<TextBlock
                        x:Name="SelectedGamePathText"
                        Grid.Row="2"
                        Margin="0,10,0,0"
                        Foreground="#AAB3C2"
                        Text="Choose a game from your library."
                        TextWrapping="Wrap" />

					<TextBlock
                        x:Name="StatusText"
                        Grid.Row="3"
                        Margin="0,22,0,0"
                        Foreground="#C8D1E0"
                        Text="Status: Ready."
                        TextWrapping="Wrap" />

					<Grid
                        Grid.Row="4"
                        Margin="0,24,0,0"
                        ColumnDefinitions="*,Auto">

						<Button
                            x:Name="LaunchButton"
                            Grid.Column="0"
                            Padding="20,13"
                            HorizontalAlignment="Stretch"
                            Click="LaunchButton_Click"
                            Content="Launch Game"
                            IsEnabled="False" />

						<Button
                            x:Name="RemoveButton"
                            Grid.Column="1"
                            Margin="12,0,0,0"
                            Padding="20,13"
                            Click="RemoveButton_Click"
                            Content="Remove"
                            IsEnabled="False" />

					</Grid>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</Window>