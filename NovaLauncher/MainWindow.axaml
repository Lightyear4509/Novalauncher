<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:viewModels="using:NovaLauncher.ViewModels"
	x:DataType="viewModels:MainWindowViewModel"
	xmlns:models="using:NovaLauncher.Models"
    x:Class="NovaLauncher.Views.MainWindow"
    Title="NovaLauncher"
    Width="1050"
    Height="680"
    MinWidth="800"
    MinHeight="520"
    Background="#10131A">

	<Grid RowDefinitions="70,*">

		<!-- Header -->
		<Border
            Grid.Row="0"
            Background="#171B24"
            BorderBrush="#292F3D"
            BorderThickness="0,0,0,1">

			<Grid
                Margin="24,0"
                ColumnDefinitions="Auto,*,Auto">

				<TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="White"
                    Text="NovaLauncher" />

				<TextBlock
                    Grid.Column="1"
                    Margin="35,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#98A2B3"
                    Text="Your personal game library" />

				<Button
					Grid.Column="2"
					Padding="18,10"
					VerticalAlignment="Center"
					Command="{Binding AddGameCommand}"
					Content="+ Add Game" />

			</Grid>
		</Border>

		<!-- Main content -->
		<Grid
            Grid.Row="1"
            Margin="24"
            ColumnDefinitions="360,*">

			<!-- Library -->
			<Border
                Grid.Column="0"
                Padding="16"
                Background="#171B24"
                BorderBrush="#303747"
                BorderThickness="1"
                CornerRadius="12">

				<Grid RowDefinitions="Auto,*,Auto">

					<TextBlock
                        Grid.Row="0"
                        Margin="4,0,0,14"
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="Game Library" />

					<ListBox
                        x:Name="GameList"
                        Grid.Row="1"
                        Background="Transparent"
                        BorderThickness="0"
						ItemsSource="{Binding Games}"
						SelectedItem="{Binding SelectedGame, Mode=TwoWay}"
                        SelectionChanged="GameList_SelectionChanged">

						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="models:Game">

								<Border
                                    Margin="0,4"
                                    Padding="12"
                                    Background="#202632"
                                    CornerRadius="8">

									<StackPanel Spacing="5">

										<TextBlock
                                            FontSize="17"
                                            FontWeight="SemiBold"
                                            Foreground="White"
                                            Text="{Binding Name}" />

										<TextBlock
                                            MaxWidth="300"
                                            Foreground="#98A2B3"
                                            Text="{Binding ExecutablePath}"
                                            TextTrimming="CharacterEllipsis" />

									</StackPanel>
								</Border>

							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>

					<TextBlock
                        x:Name="LibraryCountText"
                        Grid.Row="2"
                        Margin="4,14,0,0"
                        Foreground="#98A2B3"
                        Text="{Binding LibraryCount}" />

				</Grid>
			</Border>

			<!-- Selected game details -->
			<Border
				Grid.Column="1"
				Margin="24,0,0,0"
				Padding="30"
				Background="#171B24"
				BorderBrush="#303747"
				BorderThickness="1"
				CornerRadius="12">

				<Grid RowDefinitions="260,Auto,Auto,Auto,*,Auto">

					<!-- Cover preview -->
					<Border
						Grid.Row="0"
						Background="#252C39"
						CornerRadius="10"
						ClipToBounds="True">

						<Grid>
							<StackPanel
								x:Name="CoverPlaceholder"
								HorizontalAlignment="Center"
								VerticalAlignment="Center"
								Spacing="10">

								<TextBlock
									HorizontalAlignment="Center"
									FontSize="70"
									Text="🎮" />

								<TextBlock
									Foreground="#98A2B3"
									Text="No cover selected" />

							</StackPanel>

							<Image
								x:Name="CoverImage"
								IsVisible="False"
								Stretch="UniformToFill" />
						</Grid>
					</Border>

					<!-- Editable name -->
					<StackPanel
						Grid.Row="1"
						Margin="0,22,0,0"
						Spacing="7">

						<TextBlock
							FontWeight="SemiBold"
							Foreground="#98A2B3"
							Text="Display name" />

						<TextBox
							x:Name="GameNameTextBox"
							FontSize="20"
							Watermark="Game name"
							IsEnabled="False"
							Text="{Binding GameName, Mode=TwoWay}" />

					</StackPanel>

					<!-- Executable path -->
					<TextBlock
						x:Name="SelectedGamePathText"
						Grid.Row="2"
						Margin="0,14,0,0"
						Foreground="#AAB3C2"
						Text="{Binding SelectedGamePath}"
						TextWrapping="Wrap" />

					<!-- Editing buttons -->
					<Grid
						Grid.Row="3"
						Margin="0,16,0,0"
						ColumnDefinitions="Auto,Auto,*">

						<Button
							x:Name="SaveNameButton"
							Grid.Column="0"
							Padding="16,9"
							Command="{Binding SaveNameCommand}"
							Content="Save Name"
							IsEnabled="False" />

						<Button
							x:Name="ChooseCoverButton"
							Grid.Column="1"
							Margin="10,0,0,0"
							Padding="16,9"
							Click="ChooseCoverButton_Click"
							Content="Choose Cover"
							IsEnabled="False" />

						<Button
							x:Name="RemoveCoverButton"
							Grid.Column="2"
							Margin="10,0,0,0"
							Padding="16,9"
							HorizontalAlignment="Left"
							Click="RemoveCoverButton_Click"
							Content="Remove Cover"
							IsEnabled="False" />

					</Grid>

					<!-- Game actions -->
					<Grid
						Grid.Row="5"
						Margin="0,24,0,0"
						ColumnDefinitions="*,Auto">

						<Button
							x:Name="LaunchButton"
							Content="Launch"
							Command="{Binding LaunchGameCommand}" />

						<Button
							Grid.Column="1"
							Margin="12,0,0,0"
							Padding="20,13"
							Command="{Binding RemoveGameCommand}"
							Content="Remove" />

					</Grid>
				</Grid>
			</Border>
		</Grid>
	</Grid>
</Window>