<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="using:NovaLauncher.Converters"
             x:Class="NovaLauncher.App"
             RequestedThemeVariant="Default">

	<Application.Resources>
		<converters:CoverImageConverter
            x:Key="CoverImageConverter" />
	</Application.Resources>

	<Application.Styles>
		<FluentTheme />
	</Application.Styles>

</Application>